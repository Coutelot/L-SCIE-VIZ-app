Database[,"Average"]
PondB_temp_Loc3[,"Average"]


PondB_temp_Loc3$Average <- as.numeric(as.character(TempLoc3$Average))
PondB_temp_Loc3$date <- as.Date(TempLoc3$date, origin = "1899-12-30")


PondB_temp_Loc3 <- PondB_temp_Loc3 %>% 
  rename("Average" = "temp",
         "Depth_av" = "depth")



#######Loc3#######################################################################################################
PondB_temp_Loc3 %>% 
  summarise(min(date), max(date), n_distinct(date))

PondB_temp_Loc3_yearless <- PondB_temp_Loc3 %>%
  mutate(
    day_in_year = as.numeric(date - floor_date(date, unit = "years"), unit = "days"),
    date_label = ymd("2021-06-15") + day_in_year
  )

# 
smooth_fit_loc3 <- loess(
  temp ~ day_in_year + depth, 
  data = PondB_temp_Loc3_yearless, 
  span = .3
)

####### Average of 3 years ##############################################
temp_raster_smooth_Loc3 <- crossing(
  tibble(date = seq(ymd("2021-01-01"), ymd("2022-12-31"), by = 1)),
  tibble(depth = seq(1, 11, length.out = 100))
) %>%
  mutate(
    day_in_year = as.numeric(date - floor_date(date, unit = "years"), unit = "days"),
    temp = predict(
      smooth_fit_loc3, 
      newdata = tibble(day_in_year = day_in_year, depth = depth)
    )
  )

tiff("Loc3-Temp-Average.tiff", width=7, height=5, units='in', res=300)
Temp_Loc3<-ggplot(temp_raster_smooth_Loc3, aes(date, depth, fill = temp)) +
  geom_raster() +
  scale_y_reverse() +
  scale_fill_gradient2(
    midpoint = 15, 
    high = scales::muted("red"), 
    low = scales::muted("blue"), limits=c(5,35)
  ) +
  coord_cartesian(expand = F)
Temp_Loc3
dev.off()



