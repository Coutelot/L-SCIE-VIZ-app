# pH
PondB_pH<-read.csv("PondB_pH.csv")
PondB_pH$pH <- as.numeric(as.character(PondB_pH$pH))
PondB_pH$date <- as.Date(PondB_pH$date)

PondB_pH_Loc1 <- PondB_pH[ which(PondB_pH$Location=="Loc1"), ]
PondB_pH_Loc2 <- PondB_pH[ which(PondB_pH$Location=="Loc2"), ]
PondB_pH_Loc3 <- PondB_pH[ which(PondB_pH$Location=="Loc3"), ]
PondB_pH_Loc4 <- PondB_pH[ which(PondB_pH$Location=="Loc4"), ]
PondB_pH_Loc5 <- PondB_pH[ which(PondB_pH$Location=="Loc5"), ]


#######Loc3#######################################################################################################
#######Loc3#######################################################################################################
PondB_pH_Loc3 %>% 
  summarise(min(date), max(date), n_distinct(date))

PondB_pH_Loc3_yearless <- PondB_pH_Loc3 %>%
  mutate(
    day_in_year = as.numeric(date - floor_date(date, unit = "years"), unit = "days"),
    date_label = ymd("2019-06-15") + day_in_year
  )

# 
smooth_fit_loc3 <- loess(
  pH ~ day_in_year + depth, 
  data = PondB_pH_Loc3_yearless, 
  span = .3
)

####### Average of 3 years ##############################################
pH_raster_smooth_Loc3 <- crossing(
  tibble(date = seq(ymd("2021-01-01"), ymd("2021-12-31"), by = 1)),
  tibble(depth = seq(1, 11, length.out = 100))
) %>%
  mutate(
    day_in_year = as.numeric(date - floor_date(date, unit = "years"), unit = "days"),
    pH = predict(
      smooth_fit_loc3, 
      newdata = tibble(day_in_year = day_in_year, depth = depth)
    )
  )

tiff("Loc3-pH-Average.tiff", width=7, height=5, units='in', res=300)
pH_Loc3<-ggplot(pH_raster_smooth_Loc3, aes(date, depth, fill = pH)) +
  geom_raster() +
  scale_y_reverse() +
  scale_fill_gradient2(
    midpoint = 5.8, 
    high = scales::muted("red"), 
    low = scales::muted("blue"), limits=c(4,8)
  ) +
  coord_cartesian(expand = F)
pH_Loc3
dev.off()



